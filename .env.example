# Sendoomi Environment Variables (Cloudflare Wrangler)

# Note: For Sendoomi to deploy successfully from CI, these must matched as GitHub Secrets.

# Cloudflare Account & Authentication
# Found in: Cloudflare Dashboard URL or Overview
CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# Created at: https://dash.cloudflare.com/profile/api-tokens
# Template: 'Edit Cloudflare Pages'
CLOUDFLARE_API_TOKEN=your_api_token_here

# Cloudflare Web Analytics (Privacy First)
# Found in: Cloudflare Dashboard under 'Web Analytics'
VITE_CF_BEACON_TOKEN=your_beacon_token_here

# Application Configuration
ENVIRONMENT=development
VITE_APP_TITLE=Sendoomi (Local Preview)
